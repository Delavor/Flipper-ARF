App(
    appid="rolljam_emulate_plugin",
    apptype=FlipperAppType.PLUGIN,
    entry_point="rolljam_emulate_plugin_ep",
    requires=["rolljam_standalone"],
    fap_file_assets="keystore",
    cdefines=["ENABLE_EMULATE_FEATURE=1"],
    sources=[
        "scenes/plugins/rolljam_emulate_plugin.c",
        "protocols/protocol_items.c",
        "protocols/protocols_common.c",
    ],
    fal_embedded=True,
)


