App(
    appid="rolljam_standalone",
    name="RollJam",
    apptype=FlipperAppType.EXTERNAL,
    targets=["f7"],
    entry_point="rolljam_app",
    requires=["gui"],
    stack_size=10 * 1024,
    fap_description="RollJam Shield Receiver",
    fap_version="2.0",
    fap_category="Sub-GHz",
    cdefines=["ENABLE_SHIELD_RX_SCENE=1", "ENABLE_EMULATE_FEATURE=1"],
    fap_icon=None,
    fap_file_assets="keystore",
    sources=[
        "rolljam_app.c",
        "rolljam_app_i.c",
        "rolljam_history.c",
        "scenes/rolljam_scene.c",
        "scenes/rolljam_scene_start.c",
        "scenes/rolljam_scene_shield_receiver.c",
        "scenes/rolljam_scene_shield_receiver_config.c",
        "scenes/rolljam_scene_receiver_info.c",
        "scenes/rolljam_scene_saved.c",
        "scenes/rolljam_scene_saved_info.c",
        "scenes/rolljam_scene_need_saving.c",
        "scenes/rolljam_scene_emulate.c",
        "scenes/rolljam_scene_about.c",
//         "scenes/plugins/rolljam_psa_bf_plugin.c",
        "views/rolljam_receiver.c",
        "helpers/rolljam_rx_chain.c",
        "helpers/rolljam_tx_chain.c",
        "helpers/rolljam_storage.c",
        "helpers/rolljam_settings.c",
        "helpers/radio_device_loader.c",
        "helpers/rolljam_psa_bf_host.c",
        "protocols/protocol_items.c",
        "protocols/protocols_common.c",
        "protocols/keys.c",
        "protocols/psa_crypto.c",
        "protocols/psa_crypto_bf.c",
        "protocols/psa_bf_core.c",
        "protocols/aut64.c",
        "protocols/chrysler_v0.c",
        "protocols/fiat_v0.c",
        "protocols/fiat_v1.c",
        "protocols/ford_v0.c",
        "protocols/ford_v1.c",
        "protocols/ford_v2.c",
        "protocols/ford_v3.c",
        "protocols/honda_static.c",
        "protocols/honda_v1.c",
        "protocols/scher_khan.c",
        "protocols/keeloq.c",
        "protocols/kia_v0.c",
        "protocols/kia_v1.c",
        "protocols/kia_v2.c",
        "protocols/kia_v3_v4.c",
        "protocols/kia_v5.c",
        "protocols/kia_v6.c",
        "protocols/kia_v7.c",
        "protocols/land_rover_v0.c",
        "protocols/mazda_v0.c",
        "protocols/mitsubishi_v0.c",
        "protocols/porsche_touareg.c",
        "protocols/subaru.c",
        "protocols/vag.c",
        "protocols/star_line.c",
        "protocols/psa.c",
    ],
)

 
